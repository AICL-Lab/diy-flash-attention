#!/usr/bin/env bash
set -euo pipefail

if ! command -v pre-commit >/dev/null 2>&1; then
  echo "pre-commit is required. Install it first, then run 'make hooks-install'."
  exit 1
fi

mapfile -t files < <(git diff --cached --name-only --diff-filter=ACMR)
if [ "${#files[@]}" -eq 0 ]; then
  exit 0
fi

pre-commit run --files "${files[@]}"
